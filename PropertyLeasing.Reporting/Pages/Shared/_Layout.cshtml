<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Property Leasing Reports</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background: #f4f6f9; }
        .navbar-brand { font-weight: 700; letter-spacing: -.5px; }
        .sidebar-nav .nav-link { color: #495057; border-radius: 6px; }
        .sidebar-nav .nav-link:hover, .sidebar-nav .nav-link.active { background: #e9ecef; color: #1a3c5e; }
        .main-content { min-height: calc(100vh - 56px); }
        .dropdown-item i { width: 18px; }
    </style>
</head>
<body>

    @{
        var userName = Context.Session.GetString("user_name") ?? "Property Manager";
        var currentPath = Context.Request.Path.Value ?? "";
    }

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-md navbar-dark sticky-top" style="background: linear-gradient(90deg, #1a3c5e 0%, #2d6a9f 100%);">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-page="/Dashboard">
                <i class="bi bi-building me-2"></i>Property Leasing Reports
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link @(currentPath == "/Dashboard" ? "active fw-semibold" : "")" asp-page="/Dashboard">
                            <i class="bi bi-speedometer2 me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(currentPath.StartsWith("/Reports") ? "active fw-semibold" : "")"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-file-earmark-bar-graph me-1"></i> Reports
                        </a>
                        <ul class="dropdown-menu shadow-sm">
                            <li>
                                <a class="dropdown-item" asp-page="/Reports/Occupancy">
                                    <i class="bi bi-building text-primary"></i> Occupancy
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-page="/Reports/MaintenanceBacklog">
                                    <i class="bi bi-tools text-secondary"></i> Maintenance Backlog
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-page="/Reports/OverduePayments">
                                    <i class="bi bi-exclamation-triangle text-danger"></i> Overdue Payments
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-md-inline">@userName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><h6 class="dropdown-header">@userName</h6></li>
                            <li><span class="dropdown-item-text text-muted small"><i class="bi bi-shield-check text-success me-1"></i> Property Manager</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-page="/Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="container-fluid px-4 py-4 main-content">
        @RenderBody()
    </div>

    <footer class="border-top py-3 mt-auto bg-white">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
            <span class="text-muted small">&copy; 2026 Property Leasing &amp; Maintenance Platform</span>
            <span class="text-muted small">Reporting Portal</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
