@page
@model PropertyLeasing.Reporting.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-speedometer2 text-primary"></i> Dashboard
    </h2>
    <span class="text-muted small">Property Leasing Overview</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<!-- Occupancy Summary Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="fs-1 fw-bold text-primary">
                    @(Model.Occupancy?.OccupancyRate.ToString("F1") ?? "--")%
                </div>
                <div class="text-muted fw-semibold">Occupancy Rate</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="fs-1 fw-bold text-success">@(Model.Occupancy?.OccupiedUnits ?? 0)</div>
                <div class="text-muted fw-semibold">Occupied Units</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="fs-1 fw-bold text-warning">@(Model.Occupancy?.AvailableUnits ?? 0)</div>
                <div class="text-muted fw-semibold">Available Units</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <div class="fs-1 fw-bold text-danger">@Model.OverdueCount</div>
                <div class="text-muted fw-semibold">Overdue Payments</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Maintenance Backlog -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 fw-bold">
                <i class="bi bi-tools text-secondary"></i> Maintenance Backlog by Status
            </div>
            <div class="card-body">
                @if (Model.MaintenanceBacklog?.Count > 0)
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Status</th>
                                <th class="text-end">Count</th>
                                <th>Share</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var totalMaint = Model.MaintenanceBacklog.Sum(x => x.Count);
                            }
                            @foreach (var item in Model.MaintenanceBacklog)
                            {
                                var pct = totalMaint > 0 ? (item.Count * 100.0 / totalMaint) : 0;
                                var badgeClass = item.Status switch
                                {
                                    "Pending" => "bg-warning text-dark",
                                    "InProgress" => "bg-info text-dark",
                                    "Completed" => "bg-success",
                                    "Cancelled" => "bg-secondary",
                                    _ => "bg-light text-dark"
                                };
                                <tr>
                                    <td><span class="badge @badgeClass">@item.Status</span></td>
                                    <td class="text-end fw-semibold">@item.Count</td>
                                    <td>
                                        <div class="progress" style="height:8px; min-width:80px;">
                                            <div class="progress-bar" style="width:@pct.ToString("F0")%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No maintenance data available.</p>
                }
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-page="/Reports/MaintenanceBacklog" class="btn btn-sm btn-outline-secondary">View Full Report</a>
            </div>
        </div>
    </div>

    <!-- Quick Navigation -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 fw-bold">
                <i class="bi bi-file-earmark-bar-graph text-secondary"></i> Reports
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <a asp-page="/Reports/Occupancy" class="btn btn-outline-primary d-flex align-items-center gap-2 py-3">
                    <i class="bi bi-building fs-4"></i>
                    <div class="text-start">
                        <div class="fw-semibold">Occupancy Report</div>
                        <div class="small text-muted">Properties with unit counts and occupancy rates</div>
                    </div>
                </a>
                <a asp-page="/Reports/MaintenanceBacklog" class="btn btn-outline-secondary d-flex align-items-center gap-2 py-3">
                    <i class="bi bi-wrench fs-4"></i>
                    <div class="text-start">
                        <div class="fw-semibold">Maintenance Backlog</div>
                        <div class="small text-muted">Requests grouped by status with counts</div>
                    </div>
                </a>
                <a asp-page="/Reports/OverduePayments" class="btn btn-outline-danger d-flex align-items-center gap-2 py-3">
                    <i class="bi bi-exclamation-triangle fs-4"></i>
                    <div class="text-start">
                        <div class="fw-semibold">Overdue Payments</div>
                        <div class="small text-muted">Tenants with outstanding rent balances</div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
