@model IEnumerable<PropertyLeasing.API.Models.Property>
@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Properties</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Property</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row">
    @foreach (var p in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@p.PropertyName</h5>
                    <p class="card-text text-muted">
                        <small><i class="bi bi-geo-alt"></i> @p.Address, @p.City</small>
                    </p>
                    <span class="badge bg-secondary">@p.PropertyType</span>
                    <p class="mt-2 mb-0">
                        <strong>@(p.Units?.Count ?? 0)</strong> units
                        &nbsp;|&nbsp;
                        <strong>@(p.Units?.Count(u => u.IsAvailable) ?? 0)</strong> available
                    </p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Units" asp-route-propertyId="@p.PropertyId" class="btn btn-sm btn-outline-primary">Manage Units</a>
                    <a asp-action="Edit" asp-route-id="@p.PropertyId" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.PropertyId" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <p class="text-muted">No properties found. <a asp-action="Create">Add the first one.</a></p>
        </div>
    }
</div>
