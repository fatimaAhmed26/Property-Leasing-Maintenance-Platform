@model IEnumerable<PropertyLeasing.API.Models.Application>
@using PropertyLeasing.API.Services
@{
    ViewData["Title"] = "Lease Workflow";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Lease Workflow</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tenant</th>
                <th>Unit</th>
                <th>Property</th>
                <th>Submitted</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>#@a.ApplicationId</td>
                    <td>@a.Tenant?.FullName</td>
                    <td>@a.Unit?.UnitNumber</td>
                    <td>@a.Unit?.Property?.PropertyName</td>
                    <td>@a.SubmittedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @{
                            var badgeClass = a.Status switch
                            {
                                ApplicationStatuses.Submitted => "bg-secondary",
                                ApplicationStatuses.Pending => "bg-secondary",
                                ApplicationStatuses.Screening => "bg-info text-dark",
                                ApplicationStatuses.Approved => "bg-success",
                                ApplicationStatuses.Rejected => "bg-danger",
                                ApplicationStatuses.LeaseActive => "bg-primary",
                                ApplicationStatuses.Renewed => "bg-primary",
                                ApplicationStatuses.Terminated => "bg-dark",
                                _ => "bg-light text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@a.Status</span>
                    </td>
                    <td>
                        @if (a.Status == ApplicationStatuses.Submitted || a.Status == ApplicationStatuses.Pending)
                        {
                            <form asp-action="MoveToScreening" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@a.ApplicationId" />
                                <button class="btn btn-sm btn-outline-info">Screen</button>
                            </form>
                        }
                        @if (a.Status == ApplicationStatuses.Screening)
                        {
                            <form asp-action="Approve" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@a.ApplicationId" />
                                <button class="btn btn-sm btn-success">Approve</button>
                            </form>
                            <form asp-action="Reject" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@a.ApplicationId" />
                                <button class="btn btn-sm btn-danger">Reject</button>
                            </form>
                        }
                        @if (a.Status == ApplicationStatuses.Approved)
                        {
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal"
                                    data-bs-target="#activateModal_@a.ApplicationId">
                                Activate Lease
                            </button>

                            <!-- Activate Modal -->
                            <div class="modal fade" id="activateModal_@a.ApplicationId" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Activate Lease #@a.ApplicationId</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="Activate" method="post">
                                            <div class="modal-body">
                                                <input type="hidden" name="id" value="@a.ApplicationId" />
                                                <div class="mb-3">
                                                    <label class="form-label">Start Date</label>
                                                    <input type="date" name="startDate" class="form-control" required />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label">End Date</label>
                                                    <input type="date" name="endDate" class="form-control" required />
                                                </div>
                                                <p class="text-muted small">Monthly rent: @a.Unit?.RentAmount.ToString("C")</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-primary">Activate</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted">No applications found.</td></tr>
            }
        </tbody>
    </table>
</div>
