@model IEnumerable<PropertyLeasing.API.Models.Lease>
@{
    ViewData["Title"] = "Payments";
    var overdueIds = ViewBag.OverdueLeaseIds as HashSet<int> ?? new HashSet<int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Active Leases & Payments</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Lease ID</th>
                <th>Tenant</th>
                <th>Unit</th>
                <th>Monthly Rent</th>
                <th>Payments</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model)
            {
                var isOverdue = overdueIds.Contains(l.LeaseId);
                <tr class="@(isOverdue ? "table-danger" : "")">
                    <td>#@l.LeaseId</td>
                    <td>@l.Tenant?.FullName</td>
                    <td>@l.Unit?.UnitNumber</td>
                    <td>@l.MonthlyRent.ToString("C")</td>
                    <td>@(l.Payments?.Count ?? 0) payments</td>
                    <td>
                        @if (isOverdue)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@l.Status</span>
                        }
                    </td>
                    <td>
                        <a asp-action="LeasePayments" asp-route-leaseId="@l.LeaseId"
                           class="btn btn-sm btn-outline-primary">View History</a>
                        <button class="btn btn-sm btn-success" data-bs-toggle="modal"
                                data-bs-target="#payModal_@l.LeaseId">
                            Record Payment
                        </button>

                        <!-- Payment Modal -->
                        <div class="modal fade" id="payModal_@l.LeaseId" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Record Payment - Lease #@l.LeaseId</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form asp-action="RecordPayment" method="post">
                                        <div class="modal-body">
                                            <input type="hidden" name="leaseId" value="@l.LeaseId" />
                                            <div class="mb-3">
                                                <label class="form-label">Amount</label>
                                                <div class="input-group">
                                                    <span class="input-group-text">$</span>
                                                    <input type="number" name="amount" class="form-control"
                                                           step="0.01" value="@l.MonthlyRent" required />
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Payment Method</label>
                                                <select name="method" class="form-select">
                                                    <option>Cash</option>
                                                    <option>Bank Transfer</option>
                                                    <option>Credit Card</option>
                                                    <option>Cheque</option>
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Payment Type</label>
                                                <select name="paymentType" class="form-select">
                                                    <option value="Rent">Rent</option>
                                                    <option value="Deposit">Deposit</option>
                                                    <option value="Late Fee">Late Fee</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-success">Record</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted">No active leases found.</td></tr>
            }
        </tbody>
    </table>
</div>
