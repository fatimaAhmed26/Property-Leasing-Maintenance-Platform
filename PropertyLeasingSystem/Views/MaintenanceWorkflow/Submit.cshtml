@model PropertyLeasing.API.DTOs.SubmitMaintenanceRequestDto
@{
    ViewData["Title"] = "Submit Maintenance Request";
    var tenantUnits = ViewBag.TenantUnits as List<PropertyLeasing.API.Models.Unit> ?? new List<PropertyLeasing.API.Models.Unit>();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-3">Submit Maintenance Request</h2>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Submit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="UnitId" class="form-label">Unit</label>
                        @if (tenantUnits.Any())
                        {
                            <select asp-for="UnitId" class="form-select">
                                <option value="">-- Select your unit --</option>
                                @foreach (var u in tenantUnits)
                                {
                                    <option value="@u.UnitId">Unit @u.UnitNumber (@u.Property?.PropertyName)</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input asp-for="UnitId" class="form-control" type="number" placeholder="Enter Unit ID" />
                        }
                        <span asp-validation-for="UnitId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Describe the issue in detail..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Priority" class="form-label"></label>
                        <select asp-for="Priority" class="form-select">
                            <option value="">-- Select Priority --</option>
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                        </select>
                        <span asp-validation-for="Priority" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Submit Request</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
