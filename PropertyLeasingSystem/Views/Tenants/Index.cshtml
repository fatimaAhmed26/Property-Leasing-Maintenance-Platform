@model IEnumerable<PropertyLeasing.API.Models.Tenant>
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Tenants</h2>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Applications</th>
                <th>Leases</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td><strong>@t.FullName</strong></td>
                    <td>@t.Email</td>
                    <td>@t.Phone</td>
                    <td>@(t.Applications?.Count ?? 0)</td>
                    <td>@(t.Leases?.Count ?? 0)</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@t.TenantId" class="btn btn-sm btn-outline-primary">View Details</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted">No tenants found.</td></tr>
            }
        </tbody>
    </table>
</div>
