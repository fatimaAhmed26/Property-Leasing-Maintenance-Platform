<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Property Leasing</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PropertyLeasingSystem.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand { font-weight: 700; }
        .nav-link.active { font-weight: 600; }
        .notification-bell { position: relative; }
        .notification-badge {
            position: absolute;
            top: -4px;
            right: -6px;
            font-size: 0.65rem;
            padding: 2px 5px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    &#127968; Property Leasing
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.IsInRole("Property Manager"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Properties</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Properties" asp-action="Index">All Properties</a></li>
                                    <li><a class="dropdown-item" asp-controller="Properties" asp-action="Create">Add Property</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Tenants" asp-action="Index">Tenants</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Leases</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="LeaseWorkflow" asp-action="Index">Lease Workflow</a></li>
                                    <li><a class="dropdown-item" asp-controller="Applications" asp-action="Index">Applications</a></li>
                                    <li><a class="dropdown-item" asp-controller="Payments" asp-action="Index">Payments</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Maintenance</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="MaintenanceWorkflow" asp-action="Index">All Requests</a></li>
                                    <li><a class="dropdown-item" asp-controller="Maintenance" asp-action="Board">Live Board</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Tenant"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Applications" asp-action="Submit">Apply for Unit</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Maintenance</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="MaintenanceWorkflow" asp-action="Submit">Submit Request</a></li>
                                    <li><a class="dropdown-item" asp-controller="MaintenanceWorkflow" asp-action="Index">My Requests</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Maintenance Staff"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Maintenance</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="MaintenanceWorkflow" asp-action="Index">Work Orders</a></li>
                                    <li><a class="dropdown-item" asp-controller="Maintenance" asp-action="Board">Live Board</a></li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PublicLookup" asp-action="MaintenanceLookup">Track Request</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <!-- Notification Bell -->
                            <li class="nav-item me-2">
                                <a class="nav-link notification-bell" asp-controller="Notifications" asp-action="Index"
                                   title="Notifications">
                                    &#128276;
                                    @{
                                        // Unread count injected via ViewBag from a partial or filter
                                        var unread = ViewBag.UnreadNotificationCount as int?;
                                    }
                                    @if (unread.HasValue && unread.Value > 0)
                                    {
                                        <span class="badge bg-danger notification-badge">@unread</span>
                                    }
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    &#128100; @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Notifications" asp-action="Index">Notifications</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger">Sign Out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm ms-2" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Property Leasing &amp; Maintenance Platform
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
